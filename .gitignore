# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a venv, it might be ignored.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally recommended to be committed.
#.pdm-python.path
#.pdm-build/

# venv
#   Use virtual environments inside the project root:
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static analyzer
.pytype/

